global:
  resolve_timeout: 5m
  smtp_smarthost: '${SMTP_HOST}'
  smtp_from: '${SMTP_FROM}'
  smtp_auth_username: '${SMTP_USER}'
  smtp_auth_password: '${SMTP_PASSWORD}'
  smtp_require_tls: true

route:
  receiver: "default-slack"
  group_by: ["alertname", "cluster", "severity"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  routes:
    - matchers:
        - severity="critical"
      receiver: "critical-pager"
      continue: true
    - matchers:
        - severity="warning"
      receiver: "default-slack"

receivers:
  - name: "default-slack"
    slack_configs:
      - api_url: '${SLACK_WEBHOOK_URL}'
        channel: "#alerts-warning"
        send_resolved: true
        title: '{{ .CommonAnnotations.summary }}'
        text: '{{ .CommonAnnotations.description }}'

  - name: "critical-pager"
    slack_configs:
      - api_url: '${SLACK_WEBHOOK_URL}'
        channel: "#alerts-critical"
        send_resolved: true
    email_configs:
      - to: '${ALERT_EMAIL_TO}'
        send_resolved: true
    # Add pagerduty_configs / opsgenie_configs here if/when you wire those up.

inhibit_rules:
  - source_matchers:
      - severity="critical"
    target_matchers:
      - severity="warning"
    equal: ["alertname", "instance"]
