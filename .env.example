########################################
# Copy this to `.env` and fill in real values.
# NEVER commit the real .env to git.
########################################

# ---- General ----
DOMAIN=monitoring.example.com

# ---- Grafana ----
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme_use_a_strong_password
GF_SERVER_ROOT_URL=https://monitoring.example.com/grafana
GF_USERS_ALLOW_SIGN_UP=false
GF_AUTH_ANONYMOUS_ENABLED=false

# ---- Prometheus / Alertmanager basic auth ----
# 1. Generate the bcrypt hash: ./scripts/generate-htpasswd.sh promadmin '<password>'
# 2. Paste the resulting hash into prometheus/web.yml and alertmanager/web.yml
# 3. Put the PLAINTEXT password here too - Grafana's datasource needs it to
#    authenticate against Prometheus over basic auth (it hashes nothing itself)
PROM_BASIC_AUTH_USER=promadmin
PROM_BASIC_AUTH_PASSWORD=changeme_same_password_used_to_generate_the_hash_above
# ^ plaintext copy needed only so Grafana's datasource provisioning can
# authenticate to Prometheus. The hash in prometheus/web.yml is generated
# from this same password via generate-htpasswd.sh - keep them in sync.

# ---- Retention ----
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=20GB
LOKI_RETENTION_PERIOD=744h

# ---- Alertmanager notification channels ----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
ALERT_EMAIL_TO=oncall@example.com
SMTP_HOST=smtp.example.com:587
SMTP_FROM=alertmanager@example.com
SMTP_USER=alertmanager@example.com
SMTP_PASSWORD=changeme
